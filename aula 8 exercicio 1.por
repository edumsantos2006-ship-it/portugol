programa
{
	
	funcao inicio()
	{
		inteiro opcao


		escreva("=====menu==========\n\n")
		escreva("1 - big mac\n")
		escreva("2 - massa ao molho branco\n")
		escreva("3 - strogonoff\n")
		escreva("4 - cachorro quente\n")
		escreva("digite uma opção: ")
		leia(opcao)

		escolha(opcao){
			caso 1:
				escreva("big mac - 29,90\n")
				pare
			caso 2:
				escreva("massa ao molho branco - 50,00\n")
				pare
			caso 3:
				escreva("strogonoff saindo - 40,00")
				pare
			caso 4:
			escreva("cachorro quente pronto - 20,00")
				pare
			caso contrario:
				escreva("opção invalida, tente novamente!")
				pare
			
		}
	}
}
